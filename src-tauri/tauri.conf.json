{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GVMT",
  "version": "0.1.0",
  "identifier": "com.flowerdrunk.gvmt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GVMT",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
